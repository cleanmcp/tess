#!/usr/bin/env bash
# tess — your terminal command center. Forget everything else, just type `tess`.
set -uo pipefail

# colors — only when stdout is a real terminal (piped/agent output stays clean)
if [ -t 1 ]; then
  B=$'\033[1m'; D=$'\033[2m'; R=$'\033[0m'
  C=$'\033[36m'; G=$'\033[32m'; Y=$'\033[33m'; M=$'\033[35m'
else
  B=; D=; R=; C=; G=; Y=; M=
fi

# --- config: override any of these in ~/.config/tess/config ---
_VAULT_CONFIGURED=1; [ -z "${TESS_VAULT:-}" ] && _VAULT_CONFIGURED=0   # (re-checked after config loads)
: "${TESS_VAULT:=$HOME/Documents/tess-vault}"     # your markdown notes vault
: "${TESS_HUB:=$TESS_VAULT/hub}"                  # where tess writes NOW/people/notes
: "${TESS_WORKTREE_ROOT:=$HOME/worktrees}"        # where feature worktrees are created
: "${TESS_CORE:=$TESS_WORKTREE_ROOT/repos}"       # where your source repos live
: "${TESS_REPOS:=}"                               # default repos to fan out (space-separated)
: "${TESS_REPOS_ALL:=$TESS_REPOS}"                # repos incl. optional ones (used by --all)
: "${TESS_MAIN_BRANCH:=main}"                     # default branch (for `tess branches`)
: "${TESS_STARTUP_OPEN:=}"                        # apps `tess startup` opens (set in config)
: "${TESS_STARTUP_QUIT:=}"                        # apps `tess startup` quits (the login flood)
# config fills in what the environment didn't set — env always wins, so
# scripts (tess team, tests) can point a single command at another root.
if [ -f "$HOME/.config/tess/config" ]; then
  _prevault="$TESS_VAULT"
  _pre="$(env | grep '^TESS_' || true)"
  . "$HOME/.config/tess/config"
  while IFS='=' read -r _k _v; do [ -n "$_k" ] && eval "$_k=\$_v"; done <<< "$_pre"
  [ "$TESS_VAULT" != "$_prevault" ] && _VAULT_CONFIGURED=1
fi
export TESS_VAULT TESS_HUB TESS_WORKTREE_ROOT TESS_CORE TESS_REPOS TESS_REPOS_ALL TESS_MAIN_BRANCH TESS_STARTUP_OPEN TESS_STARTUP_QUIT
export TESS_NOTIFY_CONTACT="${TESS_NOTIFY_CONTACT:-}"   # phone pings (tess watch --phone)
export TESS_MAIL_FROM="${TESS_MAIL_FROM:-}"             # default From account (tess mail send)

# helpers live in <repo>/libexec, resolved relative to THIS script (through the
# symlink) — so a repo checkout runs its own helpers, and the installed copy
# keeps one consistent version. Layout: bin/tess + libexec/<domain>/<helper>.
_src="${BASH_SOURCE[0]}"; while [ -L "$_src" ]; do _src="$(readlink "$_src")"; done
TESS_BIN="$(cd "$(dirname "$_src")" && pwd)"
TESS_HOME="$(cd "$TESS_BIN/.." && pwd)"
TESS_LIB="$TESS_HOME/libexec"
export TESS_BIN TESS_HOME TESS_LIB
# hcom may be a real install or run via uvx (unquoted $HCOM is intentional)
command -v hcom >/dev/null 2>&1 && HCOM=hcom || HCOM="uvx hcom"
export TESS_HCOM="$HCOM"

# The backend prints its own "vX.YZ available — run `... update`" nag banner to
# stderr on some invocations. The client should only ever see tess, so strip
# that line whenever we surface backend output directly. The update mechanism
# itself is untouched (`tess update` self-updates; `tess hcom update` still runs).
_TESS_NAG='hcom v[0-9][0-9.]* available'
_hcom() {
  command -v "${HCOM%% *}" >/dev/null 2>&1 || {
    echo "tess: the fleet backend isn't available — install uv (https://docs.astral.sh/uv) so tess can run it, or install hcom directly." >&2
    return 127
  }
  $HCOM "$@" 2> >(grep --line-buffered -vE "$_TESS_NAG" >&2)
}
# external eye-candy/tools: fail with the install hint, not a raw shell error
_need() { command -v "$1" >/dev/null 2>&1 && return 0; echo "tess: '$1' isn't installed${2:+ — $2}"; return 127; }

# keep tess current: background, throttled (~6h), never blocks
[ -x "$TESS_LIB/core/update.sh" ] && nohup "$TESS_LIB/core/update.sh" >/dev/null 2>&1 &

menu() {
cat <<EOF

  ${B}${M}tess${R} ${D}— session orchestration for AI development${R}
  ${D}every stream of work is an isolated session: spawn · watch · steer · ship${R}

  ${B}${G}🌳 WORKTREES${R} ${D}(the isolation layer — one worktree per session)${R}
     ${C}tess new${R} ${D}<name>${R}               the repo you're in — or, outside a repo, your configured set
     ${C}tess new${R} ${D}<repo> <name>${R}        any repo on disk by name ${D}(unknown repo = error, never a guess)${R}
     ${C}tess new${R} ${D}… --repo a,b · --fleet · --all · --base <branch>${R}
     ${C}tess repos${R}                    the repo map — every repo on disk, ranked by use
     ${C}tess wt${R}                       worktree status — every feature: repos, branch, dirty
     ${C}tess ls${R} · ${C}rm${R} ${D}<name>${R}           list features · tear one down
     ${C}tess env${R} ${D}<name>${R}               refresh .env files into a feature (any repo)
     ${C}tess path${R} ${D}<feat> [repo]${R}       print a worktree's path — ${D}cd "\$(tess path <feat>)"${R}
     ${C}tess clean${R} · ${C}branches${R}         sweep dead worktrees · delete merged branches

  ${B}${G}📋 TODOS${R} ${D}(persistent checklist — every new agent session sees the open ones)${R}
     ${C}tess todo${R}                     list open ${D}(${C}add${R} <text> · ${C}done${R} <id> · ${C}rm${R} <id> · ${C}all${R})${R}

  ${B}${G}🤖 SESSIONS${R} ${D}(worktree + agent + context — spawn one, resume any)${R}
     ${C}tess claude${R}|${C}kimi${R} ${D}[feat] ["task"] [--model M --effort E --readonly --auto --budget N]${R}
                                 spawn — worktree auto-created, settings VERIFIED, roles ENFORCED
     ${C}tess resume${R}                   resume ANY past Claude/Kimi session (any folder)
     ${C}tess think${R} · ${C}post${R}             thinking partner · content partner ${D}(both use your vault)${R}
     ${C}tess local${R} ${D}[prompt]${R}           offline AI via ollama ${D}(also ${C}tess small${R} / ${C}big${R})${R}
     ${C}tess ask${R} ${D}"<q>"${R} · ${C}listen${R} · ${C}voice${R}  say it in words — routed + spoken ${D}(listen = hands-free)${R}
     ${C}tess loop${R} ${D}<claude|kimi> "<goal>"${R}  autonomous manager→worker loop till DONE

  ${B}${G}🚁 THE FLEET${R} ${D}(drive MANY sessions at once — you are @bigboss · backend needs uv)${R}
     ${C}tess team${R} ${D}<spec.yaml>${R}         fan out N agents (prompts/models/roles) ${D}--dry-run first${R}
     ${C}tess orchestrate${R} ${D}"<goal>"${R}     hire an AI lead ${D}('off' takes command back)${R}
     ${C}tess boss${R}                     interactive orchestrator across all your projects
     ${C}tess status${R} · ${C}digest${R}          fleet table (BLOCKED first ${D}· --json${R}) · everyone's last report
     ${C}tess report${R} ${D}<agent>${R} · ${C}diff${R} ${D}<agent|feat>${R}  one FULL report · what actually changed
     ${C}tess tell${R} ${D}<agent|feat|all> -- <msg>${R}   steer, as @bigboss (safe @-escaping)
     ${C}tess inject${R} ${D}<agent> -- <text>${R}  force a prompt into its terminal (waits + confirms)
     ${C}tess approve${R} ${D}<agent>${R}          answer a blocked approval dialog
     ${C}tess wait${R} ${D}<feat|all>${R}          block until done — exit 2 = someone needs approval
     ${C}tess watch on${R} ${D}[--phone]${R}       escalations: BLOCKED/IDLE/DIED pings the lead (or your phone)
     ${C}tess inbox${R} · ${C}spend${R}            your fleet mail · budget ledger (caps enforced at spawn)
     ${C}tess ship${R} ${D}<feat> [--merge]${R}    diff → tests → push → PR
     ${C}tess done${R} ${D}<feat>${R}              teardown: kill agents + panes + worktrees
     ${C}tess agents${R} · ${C}kill${R} ${D}<agent|feat>${R}  live dashboard · kill

  ${B}${G}🧠 BRAIN${R} ${D}(optional · any markdown notes vault — set TESS_VAULT; on-demand, no token cost)${R}
     ${C}tess${R} ${D}<name>${R}                   read a note — a person, company, topic
     ${C}tess people${R} · ${C}companies${R} · ${C}reminders${R}   rosters · every open follow-up
     ${C}tess add${R} ${D}<name> -- <text>${R}     append to a note (creates it if new)
     ${C}tess person${R}|${C}company${R} ${D}<name> -- <desc>${R}  new contact/company note (shows in roster)
     ${C}tess log${R} ${D}-- <text>${R} · ${C}brief${R} · ${C}hub${R}   quick capture · your NOW note · your hub note

  ${B}${G}📱 LIFE${R} ${D}(optional · macOS, local — grant permissions once)${R}
     ${C}tess calendar${R} ${D}[days]${R} · ${C}messages${R} ${D}[who]${R} · ${C}chat${R} ${D}<name>${R} · ${C}calls${R}
     ${C}tess send${R} ${D}<name> -- <msg>${R}     send an iMessage ${D}(always confirmed)${R}
     ${C}tess mail${R} ${D}[query]${R}             email — ${C}read${R} ${D}<id>${R} · ${C}search${R} · ${C}send${R}/${C}reply${R} ${D}(confirmed)${R} · ${C}flag${R}/${C}archive${R}/${C}move${R}
     ${C}tess music${R} ${D}[lib|top|stats]${R}    Apple Music — play + sort/filter the whole library, build playlists
     ${C}tess read${R} ${D}[title]${R}             reading companion for your current Apple Book

  ${B}${G}🖥️  APPS & STARTUP${R}
     ${C}tess${R} ${D}<app>${R} · ${C}apps${R}             open any app by name · fuzzy-pick one
     ${C}tess login${R}                    what opens at login ${D}(${C}rm${R}/${C}add${R} to edit)${R}
     ${C}tess startup${R}                  open your configured set ${D}(${C}install${R} = run at login)${R}

  ${B}${G}🩺 SYSTEM${R}
     ${C}tess git${R}                      visual git — branches/commits (lazygit)
     ${C}tess doctor${R} · ${C}disk${R}            health check · worktree disk usage
     ${C}tess update${R} · ${C}commands${R}        pull the latest · your custom commands (survive updates)
     ${C}tess cheat${R} · ${C}help${R} ${D}<cmd>${R}       the full cheatsheet · detailed help for one command
     ${C}tess fix-files${R}                permanently raise the macOS open-file limit

  ${B}${G}🐾 FUN${R} ${D}(each needs its tool installed — tess tells you which)${R}
     ${C}tess fish${R} · ${C}matrix${R} · ${C}bonsai${R} · ${C}pipes${R} · ${C}dex${R}

  ${D}type ${R}${C}tess help <command>${R}${D} for details on any one${R}

EOF
  local cdir="$HOME/.config/tess/commands"
  if [ -d "$cdir" ] && [ -n "$(ls -A "$cdir" 2>/dev/null)" ]; then
    printf "  %s%s🧩 YOUR COMMANDS%s %s(custom — survive updates)%s\n" "$B" "$G" "$R" "$D" "$R"
    for x in "$cdir"/*; do [ -x "$x" ] && printf "     %stess %s%s\n" "$C" "$(basename "$x")" "$R"; done
    echo
  fi
}

# --- vault lookup (on-demand; no per-session token cost) ---
VAULT="$TESS_VAULT"
HUB="$TESS_HUB"
_show() { command -v bat >/dev/null 2>&1 && bat --style=plain --paging=never "$1" || cat "$1"; }
_vault_ok() {
  # explicitly configured vault: self-scaffold. Unconfigured default: guide, don't
  # silently create ~/Documents/tess-vault behind the user's back.
  [ -d "$VAULT" ] && return 0
  if [ "$_VAULT_CONFIGURED" = 1 ]; then mkdir -p "$HUB" 2>/dev/null && return 0; fi
  echo "no notes vault yet — the brain features are optional. Point TESS_VAULT at any"
  echo "markdown folder in ~/.config/tess/config (Obsidian/Lokus/plain files all work)."
  return 1
}
_lookup() {
  _vault_ok || return 1
  local q="$*" exact matches n file pick
  # 1) exact note-name match wins
  exact=$(find "$VAULT" -type f -iname "${q}.md" -not -path "*/.*/*" 2>/dev/null | head -1)
  if [ -n "$exact" ]; then _show "$exact"; return 0; fi
  # 2) partial name match, else content match
  matches=$(find "$VAULT" -type f -iname "*${q}*.md" -not -path "*/.*/*" 2>/dev/null | head -20)
  [ -z "$matches" ] && matches=$(grep -rilF "$q" "$VAULT" --include="*.md" 2>/dev/null | grep -v '/\.' | head -20)
  n=$(printf '%s\n' "$matches" | grep -c .)
  if [ "$n" -eq 0 ]; then echo "tess: no note found for '${q}'. (searched your vault)"; return 1; fi
  if [ "$n" -eq 1 ]; then _show "$matches"; return 0; fi
  echo "${B}notes matching '${q}':${R}"
  printf '%s\n' "$matches" | sed "s#$VAULT/##" | nl -w2 -s'. '
  [ -t 0 ] || { echo "(multiple matches — refine the name)"; return 0; }
  printf "pick # (Enter to cancel): "; read -r pick
  case "$pick" in ''|*[!0-9]*) echo "cancelled."; return 0 ;; esac
  file=$(printf '%s\n' "$matches" | sed -n "${pick}p")
  [ -n "$file" ] && _show "$file"
}

_add() {
  # tess add <note name...> -- <text...>   (creates the note if missing)
  _vault_ok || return 1
  local name="" text="" seen=0 a file
  for a in "$@"; do
    if [ "$a" = "--" ]; then seen=1; continue; fi
    if [ $seen -eq 0 ]; then name="${name:+$name }$a"; else text="${text:+$text }$a"; fi
  done
  [ -z "$name" ] && { echo "usage: tess add <note name> -- <text>"; return 1; }
  file=$(find "$VAULT" -type f -iname "${name}.md" -not -path "*/.*/*" 2>/dev/null | head -1)
  if [ -z "$file" ]; then
    mkdir -p "$HUB/Inbox"; file="$HUB/Inbox/${name}.md"
    { echo "---"; echo "title: ${name}"; echo "tags: [inbox]";
      echo "created: $(date +%F)"; echo "description:"; echo "---"; echo;
      echo "# ${name}"; echo; } > "$file"
    echo "created ${file#$VAULT/}"
  fi
  [ -z "$text" ] && { printf "text: "; read -r text; }
  printf -- "- %s — %s\n" "$(date '+%Y-%m-%d %H:%M')" "$text" >> "$file"
  echo "✓ added to ${file#$VAULT/}"
}
_newnote() {
  # _newnote <subdir> <tag> <name...> -- <description...>
  _vault_ok || return 1
  local sub="$1" tag="$2"; shift 2
  local name="" desc="" seen=0 a file
  for a in "$@"; do
    if [ "$a" = "--" ]; then seen=1; continue; fi
    if [ $seen -eq 0 ]; then name="${name:+$name }$a"; else desc="${desc:+$desc }$a"; fi
  done
  [ -z "$name" ] && { echo "usage: tess ${sub%s} <name> -- <description>"; return 1; }
  mkdir -p "$HUB/$sub"; file="$HUB/$sub/${name}.md"
  if [ ! -f "$file" ]; then
    { echo "---"; echo "title: ${name}"; echo "tags: [${tag}]";
      echo "created: $(date +%F)"; echo "description: ${desc}"; echo "---"; echo;
      echo "# ${name}"; echo; [ -n "$desc" ] && { echo "$desc"; echo; }
      echo "## Notes"; } > "$file"
    echo "✓ created ${sub}/${name}"
  else
    [ -n "$desc" ] && printf -- "- %s — %s\n" "$(date '+%Y-%m-%d %H:%M')" "$desc" >> "$file"
    echo "✓ updated ${sub}/${name}"
  fi
  _show "$file"
}
_log() {
  # tess log -- <text>   quick timestamped capture into the running log
  _vault_ok || return 1
  local text="$*"; text="${text#-- }"
  [ -z "$text" ] && { printf "log: "; read -r text; }
  mkdir -p "$HUB"; local f="$HUB/Log.md"
  [ -f "$f" ] || { echo "---"; echo "title: Log"; echo "tags: [log]"; echo "created: $(date +%F)"; echo "description: Running quick-capture log."; echo "---"; echo; echo "# Log"; echo; } > "$f"
  printf -- "- **%s** — %s\n" "$(date '+%Y-%m-%d %H:%M')" "$text" >> "$f"
  echo "✓ logged"
}
_mode() {
  # _mode <name> — path of an agent-mode prompt. Your override in
  # ~/.config/tess/modes wins, then the repo's copy (always present, stays
  # current with `tess update`), then a legacy ~/.claude/modes install.
  for m in "$HOME/.config/tess/modes/$1.md" "$TESS_HOME/modes/$1.md" "$HOME/.claude/modes/$1.md"; do
    [ -f "$m" ] && { echo "$m"; return 0; }
  done
  echo "tess: mode '$1' not found (looked in ~/.config/tess/modes, $TESS_HOME/modes)" >&2; return 1
}
_localrun() {
  # _localrun <tier> [prompt...]  — run the local model for that size tier
  command -v ollama >/dev/null 2>&1 || { echo "ollama not installed (brew install ollama)"; return 1; }
  local tier="$1"; shift
  local m; m=$(grep "^${tier}=" "$HOME/.config/tess/models" 2>/dev/null | cut -d= -f2)
  [ -z "$m" ] && m="llama3.2:3b"
  if ! ollama list 2>/dev/null | awk '{print $1}' | grep -qx "$m"; then
    echo "model '$m' ($tier) not pulled yet — run:  ollama pull $m"; return 1
  fi
  if [ $# -gt 0 ]; then exec ollama run "$m" "$*"; else exec ollama run "$m"; fi
}

cmd="${1:-menu}"; shift 2>/dev/null || true

# ---- safety rails (B1) ------------------------------------------------------
# A help flag must NEVER create a worktree or spawn an agent. Any -h/--help
# after a subcommand shows that subcommand's help and exits — before anything
# else runs. (`--` ends the scan so message text can mention --help; the hcom
# passthrough is exempt so `tess hcom send --help` shows hcom's own help.)
case "$cmd" in
  hcom) ;;
  *) for _a in "$@"; do case "$_a" in
       -h|--help) exec bash "$TESS_LIB/core/help.sh" "$cmd" ;;
       --) break ;;
     esac; done ;;
esac

# words that can never be feature/agent names (subcommands + obvious traps)
TESS_RESERVED="help menu new repos ls list rm remove clean env branches path wt worktrees claude kimi agents agent loop resume r local offline small big med medium think partner post write brand boss ask voice listen git lg fish matrix bonsai pipes dex doctor disk cheat fix-files fixfiles update commands custom open app launch apps login startup brief hub person company add log people companies reminders todo todos followups calendar cal messages msg chat thread send text calls mail email music read book readpos done inbox report digest status team orchestrate ship wait watch approve inject tell kill hcom diff spend all"
export TESS_RESERVED
_validname() {  # _validname <name> <what> — reject flag-like/reserved/path-unsafe names
  local n="${1:-}" what="${2:-name}"
  [ -z "$n" ] && { echo "tess: missing $what" >&2; return 1; }
  case "$n" in
    -*) echo "tess: '$n' looks like a flag, not a $what. (want help? tess help $cmd)" >&2; return 1 ;;
    .*|*/*|*[!A-Za-z0-9._-]*) echo "tess: '$n' is not a safe $what (letters, digits, . _ - only)" >&2; return 1 ;;
  esac
  case " $TESS_RESERVED " in
    *" $n "*) echo "tess: '$n' is a reserved tess word — pick another $what" >&2; return 1 ;;
  esac
  return 0
}

case "$cmd" in
  menu|""|-h|--help) menu ;;
  help) if [ $# -gt 0 ]; then exec bash "$TESS_LIB/core/help.sh" "$@"; else menu; fi ;;
  update)   exec bash "$TESS_LIB/core/update.sh" --now ;;
  todo|todos)    exec bash "$TESS_LIB/core/todo.sh" "$@" ;;
  commands|custom)
    cdir="$HOME/.config/tess/commands"; mkdir -p "$cdir"
    case "${1:-list}" in
      new|add|create)
        [ -z "${2:-}" ] && { echo "usage: tess commands new <name>"; exit 1; }
        f="$cdir/$2"
        if [ ! -e "$f" ]; then
          printf '#!/usr/bin/env bash\n# tess %s — custom command. Args come in as \$@.\n# Config vars (TESS_VAULT etc.) are exported and available here.\necho "hello from tess %s ($*)"\n' "$2" "$2" > "$f"
          chmod +x "$f"
        fi
        echo "created $f — edit it, then run: tess $2"
        ${EDITOR:-open} "$f" 2>/dev/null || true ;;
      *) echo "${B}your custom commands${R} ${D}($cdir)${R}"
         if [ -n "$(ls -A "$cdir" 2>/dev/null)" ]; then
           for x in "$cdir"/*; do [ -x "$x" ] && echo "  ${C}tess $(basename "$x")${R}"; done
         else echo "  ${D}(none yet — make one: tess commands new <name>)${R}"; fi ;;
    esac ;;

  # apps + login/startup
  open|app|launch) exec bash "$TESS_LIB/life/apps.sh" open "$@" ;;
  apps)     exec bash "$TESS_LIB/life/apps.sh" apps ;;
  login)    exec bash "$TESS_LIB/life/apps.sh" login "$@" ;;
  startup)  exec bash "$TESS_LIB/life/apps.sh" startup "$@" ;;

  # worktrees ---------------------------------------------------------------
  new)      # grammar: tess new [<repo>] <feature> [--repo a,b] [--fleet|--all] [--base <br>]
    # the feature is the LAST positional — validate that one; repo names are
    # checked by worktree.sh itself (unknown repo = clean error, never reinterpreted)
    _feat=""; _skip=0
    for _a in "$@"; do
      [ "$_skip" = 1 ] && { _skip=0; continue; }
      case "$_a" in --repo|--base) _skip=1 ;; -*) ;; *) _feat="$_a" ;; esac
    done
    [ -n "$_feat" ] && { _validname "$_feat" "feature name" || exit 2; }
    "$TESS_LIB/worktrees/wt" "$@" ;;
  repos)    exec bash "$TESS_LIB/worktrees/repos.sh" "$@" ;;
  ls|list)  echo "${B}Your features:${R}"; "$TESS_LIB/worktrees/wt" ls ;;
  rm)       _validname "${1:-}" "feature name" || exit 2; "$TESS_LIB/worktrees/wt" rm "$@" ;;
  clean)    "$TESS_LIB/worktrees/wt" prune ;;

  path)     # print a worktree path (for agents: cd "$(tess path <feature> [repo])")
    feat="${1:-}"; repo="${2:-}"
    [ -z "$feat" ] && { echo "usage: tess path <feature> [repo]" >&2; exit 1; }
    _validname "$feat" "feature name" || exit 2
    p="$TESS_WORKTREE_ROOT/$feat"; [ -n "$repo" ] && p="$p/$repo"
    if [ -z "$repo" ] && [ -d "$p" ] && [ ! -e "$p/.git" ]; then
      # single-repo feature: hand back the repo dir itself, so whoever cd's
      # here lands INSIDE a git repo (multi-repo features return the root)
      _subs=()
      for _sub in "$p"/*/; do [ -e "${_sub%/}/.git" ] && _subs+=("${_sub%/}"); done
      [ "${#_subs[@]}" -eq 1 ] && p="${_subs[0]}"
    fi
    [ -e "$p" ] && echo "$p" || { echo "not found: $p" >&2; exit 1; }
    ;;

  wt|worktrees)  # worktree status: every feature, its repos, branch + dirty + source
    _found=0
    for _f in "$TESS_WORKTREE_ROOT"/*/; do
      [ -d "$_f" ] || continue
      _feat="$(basename "$_f")"
      [ "$_feat" = "$(basename "$TESS_CORE")" ] && continue
      _subs=()
      [ -e "${_f%/}/.git" ] && _subs+=("${_f%/}")
      for _sub in "$_f"*/; do [ -e "${_sub%/}/.git" ] && _subs+=("${_sub%/}"); done
      [ "${#_subs[@]}" -eq 0 ] && continue
      _found=1
      echo "${B}$_feat${R}"
      for _d in "${_subs[@]}"; do
        _br="$(git -C "$_d" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
        _dirty="$(git -C "$_d" status --porcelain 2>/dev/null | grep -c . || true)"
        _gd="$(sed -n 's/^gitdir: //p' "$_d/.git" 2>/dev/null || true)"
        _srcr=""; case "$_gd" in */.git/worktrees/*) _srcr="${_gd%/.git/worktrees/*}" ;; esac
        _state="clean"; [ "${_dirty:-0}" -gt 0 ] && _state="${Y}${_dirty} dirty${R}"
        printf '  %-22s %-22s %-10s %s\n' "$(basename "$_d")" "$_br" "$_state" "${_srcr:+${D}← ${_srcr/#$HOME/~}${R}}"
      done
    done
    [ "$_found" = 0 ] && echo "no feature worktrees yet. (create one: tess new <feature>)"
    ;;

  env)
    feat="${1:-}"; [ -z "$feat" ] && { echo "usage: tess env <feature>"; exit 1; }
    _validname "$feat" "feature name" || exit 2
    fdir="$TESS_WORKTREE_ROOT/$feat"
    [ -d "$fdir" ] || { echo "no feature '$feat' (see: tess ls)"; exit 1; }
    echo "${B}refreshing env for '$feat'${R}"
    # iterate the worktrees actually IN the feature and follow each one's own
    # gitdir pointer back to its source repo — works for ANY repo, not just the
    # configured fleet.
    _dsts=()
    [ -f "$fdir/.git" ] && _dsts+=("$fdir")
    for _sub in "$fdir"/*/; do [ -f "${_sub%/}/.git" ] && _dsts+=("${_sub%/}"); done
    [ "${#_dsts[@]}" -eq 0 ] && { echo "  (no worktrees inside '$feat')"; exit 0; }
    for dst in "${_dsts[@]}"; do
      gd="$(sed -n 's/^gitdir: //p' "$dst/.git" 2>/dev/null || true)"
      case "$gd" in */.git/worktrees/*) src="${gd%/.git/worktrees/*}" ;; *) src="$TESS_CORE/$(basename "$dst")" ;; esac
      [ -d "$src" ] || { echo "  ${Y}$(basename "$dst")${R} — source repo not found ($src), skipped"; continue; }
      echo "  ${Y}$(basename "$dst")${R} ${D}← ${src/#$HOME/~}${R}"
      find "$src" \( -name node_modules -o -name .git -o -name .next -o -name dist -o -name build \) -prune -o \
        -type f \( -name '.env' -o -name '.env.*' \) ! -name '*.example' ! -name '*.sample' -print0 |
      while IFS= read -r -d '' f; do
        rel="${f#"$src"/}"; mkdir -p "$dst/$(dirname "$rel")"; cp -p "$f" "$dst/$rel"; echo "    ${G}✓${R} $rel"
      done
    done
    ;;

  branches)
    echo "${B}branches already merged into $TESS_MAIN_BRANCH (safe to delete):${R}"
    found=0
    for repo in $TESS_REPOS; do
      d="$TESS_CORE/$repo"
      list=$(git -C "$d" branch --merged "$TESS_MAIN_BRANCH" 2>/dev/null | grep -vE "^\*| ${TESS_MAIN_BRANCH}\$" | sed "s/^[+ ]*//" | grep -v "^${TESS_MAIN_BRANCH}\$")
      [ -n "$list" ] && { echo "  ${Y}$repo:${R}"; echo "$list" | sed 's/^/    /'; found=1; }
    done
    [ "$found" = 0 ] && { echo "  ${G}nothing to clean — all tidy${R}"; exit 0; }
    printf "\n${B}delete all of these? [y/N]${R} "; read -r yn
    if [[ "$yn" =~ ^[Yy]$ ]]; then
      for repo in $TESS_REPOS; do
        d="$TESS_CORE/$repo"
        git -C "$d" branch --merged "$TESS_MAIN_BRANCH" 2>/dev/null | grep -vE "^\*| ${TESS_MAIN_BRANCH}\$" | sed "s/^[+ ]*//" | grep -v "^${TESS_MAIN_BRANCH}\$" \
          | while read -r b; do git -C "$d" branch -d "$b" 2>/dev/null && echo "  ${G}deleted${R} $repo/$b"; done
      done
    else echo "skipped."; fi
    ;;

  # agents ---------------------------------------------------------------
  claude|kimi)
    # tess claude|kimi                      interactive, current tab (unchanged)
    # tess claude|kimi <feat|.> ["prompt"] [--file f] [--model m] [--effort e]
    #   feat -> create the worktree if missing, spawn in a new pane there.
    #   The spawner GUARANTEES model/effort/prompt actually apply (launch flags
    #   don't always stick through the PTY) — see libexec/fleet/spawn.py.
    [ $# -eq 0 ] && { _hcom "$cmd" --run-here; exit $?; }
    exec python3 "$TESS_LIB/fleet/spawn.py" "$cmd" "$@"
    ;;
  agents)   # bare = live fleet dashboard; --json = machine-readable fleet state
    case "${1:-}" in --json) exec python3 "$TESS_LIB/fleet/hq.py" status --json ;; esac
    _hcom; exit $? ;;
  status)   exec python3 "$TESS_LIB/fleet/hq.py" status "$@" ;;
  diff)     exec python3 "$TESS_LIB/fleet/hq.py" diff "$@" ;;
  approve)  exec python3 "$TESS_LIB/fleet/hq.py" approve "$@" ;;
  inject)   exec python3 "$TESS_LIB/fleet/inject.py" "$@" ;;
  done)     _validname "${1:-}" "feature name" || exit 2; exec python3 "$TESS_LIB/fleet/done.py" "$@" ;;
  hcom)     _hcom "$@"; exit $? ;;   # raw backend passthrough (power users/agents): tess hcom <anything>
  report)   exec python3 "$TESS_LIB/fleet/hq.py" report "$@" ;;
  digest)   exec python3 "$TESS_LIB/fleet/hq.py" digest "$@" ;;
  tell)     exec python3 "$TESS_LIB/fleet/comms.py" tell "$@" ;;
  inbox)    exec python3 "$TESS_LIB/fleet/comms.py" inbox "$@" ;;
  team)     exec python3 "$TESS_LIB/fleet/team.py" "$@" ;;
  orchestrate|orch) exec python3 "$TESS_LIB/fleet/orchestrate.py" "$@" ;;
  ship)     _validname "${1:-}" "feature name" || exit 2; exec python3 "$TESS_LIB/fleet/ship.py" ship "$@" ;;
  spend)    exec python3 "$TESS_LIB/fleet/ship.py" spend "$@" ;;
  wait)     exec python3 "$TESS_LIB/fleet/watch.py" wait "$@" ;;
  watch)    exec python3 "$TESS_LIB/fleet/watch.py" watch "$@" ;;
  kill)
    tgt="${1:-}"; [ -z "$tgt" ] && { echo "usage: tess kill <agent|feature|tag:X|all>"; exit 1; }
    if [ -d "$TESS_WORKTREE_ROOT/$tgt" ]; then
      shift; exec python3 "$TESS_LIB/fleet/done.py" "$tgt" --agents-only "$@"   # feature: its agents only
    fi
    _hcom kill "$@"; exit $?
    ;;
  loop)     exec bash "$TESS_LIB/fleet/loop.sh" "$@" ;;
  resume|r) exec python3 "$TESS_LIB/fleet/resume.py" ;;
  local|offline)   # offline AI (no internet). `tess local [small|big] [prompt]`
    case "${1:-}" in
      small|med|medium|big) t="$1"; shift; _localrun "$t" "$@" ;;
      *) _localrun med "$@" ;;
    esac
    ;;
  small)  _localrun small "$@" ;;   # fastest local model
  big)    _localrun big "$@" ;;     # best-quality local model your Mac can run
  think|partner)
    # thinking-partner mode: company context, sounding board (not idea-firehose),
    # researches in the background while it keeps talking to you.
    m="$(_mode think)" || exit 1
    exec claude --add-dir "$TESS_VAULT" --append-system-prompt "$(cat "$m")" "$@"
    ;;
  post|write|brand)
    # daily content partner: your voice + proven mechanics, learns your taste each session.
    m="$(_mode post)" || exit 1
    exec claude --add-dir "$TESS_VAULT" --append-system-prompt "$(cat "$m")" "$@"
    ;;
  boss)
    # interactive multi-project orchestrator: you talk to it, it routes/spawns/coordinates
    # the fleet across ALL projects. Boots oriented; if no ask is passed, it runs its
    # on-start orientation first so it knows the lay of the land before your first turn.
    m="$(_mode boss)" || exit 1
    boss_boot="Boot: run your on-start orientation now (tess wt, tess ls, tess status, uvx hcom list, tess brief) to get oriented, then give me a tight board of the current lay of the land and wait for my first ask."
    exec claude --add-dir "$TESS_VAULT" \
      --append-system-prompt "$(cat "$m")" "${@:-$boss_boot}"
    ;;

  # tools -------------------------------------------------------------------
  git|lg)   _need lazygit "brew install lazygit" && exec lazygit ;;

  # fun ---------------------------------------------------------------------
  fish)     _need asciiquarium "brew install asciiquarium" && exec asciiquarium ;;
  matrix)   _need cmatrix "brew install cmatrix" && exec cmatrix -b ;;
  bonsai)   _need cbonsai "brew install cbonsai" && exec cbonsai -l -i ;;
  pipes)    _need pipes.sh "brew install pipes-sh" && exec pipes.sh ;;
  dex)      _need pokemon-colorscripts "https://gitlab.com/phoneybadger/pokemon-colorscripts" && pokemon-colorscripts -r ;;

  # system doctor -----------------------------------------------------------
  doctor)
    echo "${B}🩺 system check${R}"
    max=$(sysctl -n kern.maxfiles 2>/dev/null); now=$(sysctl -n kern.num_files 2>/dev/null)
    if [ -n "${max:-}" ] && [ -n "${now:-}" ]; then
      pct=$(( now * 100 / max ))
      printf "  open files:  %s / %s  (%s%%)  " "$now" "$max" "$pct"
      if [ "$pct" -ge 85 ]; then echo "${Y}⚠ HIGH — close dev servers / reboot${R}";
      elif [ "$max" -lt 100000 ]; then echo "${Y}⚠ low ceiling — run: tess fix-files${R}";
      else echo "${G}ok${R}"; fi
    fi
    printf "  features:    "; "$TESS_LIB/worktrees/wt" ls 2>/dev/null | grep -c .
    printf "  local model: "
    if command -v ollama >/dev/null 2>&1; then ollama list 2>/dev/null | awk 'NR==2{print $1" ("$3$4")"}' | grep . || echo "none pulled"; else echo "ollama not installed"; fi
    echo "  ${D}(disk size: run 'tess disk' — it's slow on big node_modules)${R}"
    ;;

  disk)
    echo "${B}measuring worktrees (may take a bit)...${R}"
    du -sh "$TESS_WORKTREE_ROOT" 2>/dev/null
    echo "${D}biggest features:${R}"
    du -sh "$TESS_WORKTREE_ROOT"/*/ 2>/dev/null | sort -rh | head -6
    ;;

  cheat)    # the closest thing to a cheatsheet is the bundled README
    readme="$TESS_HOME/README.md"
    if [ -f "$readme" ]; then _show "$readme"
    else echo "run ${C}tess${R} for the full menu, or ${C}tess help <command>${R} for one command."; fi ;;

  fix-files|fixfiles)   # permanently raise the macOS open-file limit (asks for your password)
    [ "$(uname)" = "Darwin" ] || { echo "macOS only."; exit 1; }
    echo "${B}raising the open-file limit (needs your password)…${R}"
    plist=/Library/LaunchDaemons/limit.maxfiles.plist
    sudo tee "$plist" >/dev/null <<'PL'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>limit.maxfiles</string>
  <key>ProgramArguments</key><array><string>launchctl</string><string>limit</string><string>maxfiles</string><string>524288</string><string>524288</string></array>
  <key>RunAtLoad</key><true/><key>ServiceIPC</key><false/>
</dict></plist>
PL
    sudo chown root:wheel "$plist"
    sudo launchctl load -w "$plist" 2>/dev/null || true
    sudo sysctl -w kern.maxfiles=524288 kern.maxfilesperproc=131072 >/dev/null
    echo "${G}✓ done${R} — cap raised now and on every reboot. Check with: tess doctor"
    ;;

  # --- brain / notes ---
  brief)    _vault_ok && { [ -f "$HUB/NOW.md" ] && _show "$HUB/NOW.md" || echo "no NOW note yet — start it: tess add NOW -- <what's going on>"; } ;;
  hub)      _vault_ok && { [ -f "$HUB/hub.md" ] && _show "$HUB/hub.md" || echo "no hub note yet — start it: tess add hub -- <text>"; } ;;
  person)   _newnote "People" "person" "$@" ;;
  company)  if [ $# -gt 0 ]; then _newnote "Companies" "company" "$@"; else _show "$HUB/hub.md"; fi ;;
  add)      _add "$@" ;;
  log)      _log "$@" ;;
  people)   python3 "$TESS_LIB/brain/list.py" people ;;
  companies|company-list) python3 "$TESS_LIB/brain/list.py" companies ;;
  reminders|followups) python3 "$TESS_LIB/brain/list.py" reminders ;;

  # --- life (macOS: calendar / messages / calls) ---
  calendar|cal) exec python3 "$TESS_LIB/life/cal.py" "$@" ;;
  messages|msg) python3 "$TESS_LIB/life/messages.py" "$@" ;;
  chat|thread)  python3 "$TESS_LIB/life/chat.py" "$@" ;;
  send|text)    exec bash "$TESS_LIB/life/send.sh" "$@" ;;
  calls)        python3 "$TESS_LIB/life/calls.py" ;;
  mail|email)   python3 "$TESS_LIB/life/mail.py" "$@" ;;
  music)        exec python3 "$TESS_LIB/life/music.py" "$@" ;;
  read|book)    exec python3 "$TESS_LIB/life/read.py" "$@" ;;
  readpos)      python3 "$TESS_LIB/life/readpos.py" "$@" ;;

  ask)      exec python3 "$TESS_LIB/brain/ask.py" "$@" ;;
  voice)
    echo "🎙  type or dictate (Wispr Flow) — Ctrl+C to stop."
    while printf "\n🎙  tess> " && read -r line; do
      [ -z "$line" ] && continue
      python3 "$TESS_LIB/brain/ask.py" $line
    done
    ;;
  listen)   exec bash "$TESS_LIB/brain/listen.sh" ;;   # hands-free wake word

  *)
    # user's custom commands live in ~/.config/tess/commands/ (never in the repo,
    # so `git pull` never overwrites them). tess <name> -> run that script.
    if [ -x "$HOME/.config/tess/commands/$cmd" ]; then
      exec "$HOME/.config/tess/commands/$cmd" "$@"
    fi
    # bare `tess <word>`: an installed app -> open it
    if [ $# -eq 0 ]; then
      _appm=$(find /Applications /System/Applications "$HOME/Applications" -maxdepth 2 -iname "${cmd}.app" 2>/dev/null | head -1)
      [ -z "$_appm" ] && _appm=$(find /Applications /System/Applications "$HOME/Applications" -maxdepth 2 -iname "${cmd}*.app" 2>/dev/null | head -1)
      if [ -n "$_appm" ]; then open "$_appm" && echo "▶ opened $(basename "$_appm" .app)"; exit 0; fi
    fi
    # a sentence/question -> voice router; a short name -> note lookup
    if [ $# -ge 3 ] || printf '%s %s' "$cmd" "$*" | grep -q '?'; then
      exec python3 "$TESS_LIB/brain/ask.py" "$cmd" "$@"
    else
      _lookup "$cmd" "$@"
    fi
    ;;
esac
