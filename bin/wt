#!/usr/bin/env bash
# wt — convenience wrapper around worktree.sh (multi-repo feature worktrees)
#   wt <feature> [base]       create worktrees for your repos, open in cmux
#   wt --all <feature> [base] ...also include optional repos
#   wt rm <feature>           tear the feature's worktrees back down
#   wt ls                     list existing feature worktrees in $TESS_WORKTREE_ROOT
# Worktrees land at <worktree-root>/<feature>/<repo>.
set -euo pipefail
# config fills in what the environment didn't set — env always wins
if [ -f "$HOME/.config/tess/config" ]; then
  _pre="$(env | grep '^TESS_' || true)"
  . "$HOME/.config/tess/config"
  while IFS='=' read -r _k _v; do [ -n "$_k" ] && eval "$_k=\$_v"; done <<< "$_pre"
fi

WASH="${TESS_WORKTREE_ROOT:-$HOME/worktrees}"
# prefer the worktree.sh sitting next to THIS script (works from a repo checkout too)
_src="${BASH_SOURCE[0]}"; while [ -L "$_src" ]; do _src="$(readlink "$_src")"; done
SCRIPT="$(cd "$(dirname "$_src")" && pwd)/worktree.sh"
[ -x "$SCRIPT" ] || SCRIPT="$(command -v worktree.sh || echo "$WASH/worktree.sh")"
[ -x "$SCRIPT" ] || { echo "wt: worktree.sh not found/executable" >&2; exit 1; }

case "${1:-ls}" in
  -h|--help)
    sed -n '2,7p' "$0" | sed 's/^# \{0,1\}//'; exit 0
    ;;
  ls|list|"")
    # real worktree state, not just folders: a feature is LIVE if a repo
    # subfolder is an actual git worktree; otherwise it's a ghost shell.
    find "$WASH" -mindepth 1 -maxdepth 1 -type d ! -name "$(basename "${TESS_CORE:-repos}")" -print0 |
    while IFS= read -r -d '' f; do
      feat="$(basename "$f")"; live=""
      [ -e "$f/.git" ] && live="self"   # the dir itself is a checkout/worktree
      for sub in "$f"/*/; do
        [ -e "${sub%/}/.git" ] && live="${live:+$live }$(basename "$sub")"
      done
      if [ -n "$live" ]; then printf '%s\t[%s]\n' "$feat" "$live"
      else printf '%s\t(ghost — no worktrees; tess clean removes it)\n' "$feat"; fi
    done | sort | column -t -s$'\t'
    exit 0
    ;;
  rm|remove)
    shift; exec "$SCRIPT" rm "$@"
    ;;
  prune)
    # 1) clear stale worktree registrations left behind by manual folder deletes
    for r in ${TESS_REPOS_ALL:-${TESS_REPOS:-}}; do
      d="${TESS_CORE:-$WASH/repos}/$r"
      [ -d "$d" ] && { echo "== $r =="; git -C "$d" worktree prune -v; }
    done
    # 2) sweep ghost feature shells: folders with no live worktree inside and
    #    nothing in them beyond tess's own orientation files
    find "$WASH" -mindepth 1 -maxdepth 1 -type d ! -name "$(basename "${TESS_CORE:-repos}")" -print0 |
    while IFS= read -r -d '' f; do
      live=0
      [ -e "$f/.git" ] && live=1        # the dir itself is a checkout/worktree
      for sub in "$f"/*/; do [ -e "${sub%/}/.git" ] && { live=1; break; }; done
      [ "$live" = 1 ] && continue
      leftovers="$(ls -A "$f" 2>/dev/null | grep -vx 'AGENTS.md' | grep -vx 'CLAUDE.md' || true)"
      if [ -z "$leftovers" ]; then
        rm -f "$f/AGENTS.md" "$f/CLAUDE.md"; rmdir "$f" 2>/dev/null \
          && echo "swept ghost feature: $(basename "$f")"
      else
        echo "ghost feature '$(basename "$f")' kept — still contains: $(echo "$leftovers" | tr '\n' ' ')"
      fi
    done
    echo "done. (orphan branches left intact — delete with: git -C $TESS_CORE/<repo> branch -D <name>)"
    exit 0
    ;;
esac

# create mode — run the real script, then open the new feature folder in cmux
"$SCRIPT" "$@"

# figure out the feature name (first arg that isn't a flag or a flag's value) and open it
feat=""; _skip=0
for a in "$@"; do
  [ "$_skip" = 1 ] && { _skip=0; continue; }
  case "$a" in --all|--web|--fleet) ;; --repo) _skip=1 ;; *) feat="$a"; break ;; esac
done
if [ -n "$feat" ] && [ -d "$WASH/$feat" ]; then
  cmux open "$WASH/$feat" >/dev/null 2>&1 && echo "→ opened $WASH/$feat in cmux" || true
fi
